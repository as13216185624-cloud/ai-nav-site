'use strict';
window.addEventListener('load', () => {
  // show-hide conversion banner
  const banner = document.querySelector('[data-element="conversion-banner"]');
  let hideBannerTimeout;
  function showBanner() {
    if (!banner) return;
    clearTimeout(hideBannerTimeout);
    banner.style.display = 'flex';
    banner.offsetHeight;
    banner.style.opacity = '1';
  }
  function hideBanner() {
    if (!banner) return;
    banner.style.opacity = '0';
    hideBannerTimeout = setTimeout(() => {
      banner.style.display = 'none';
    }, 300);
  }
  const bannerObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        hideBanner();
      } else {
        showBanner();
      }
    });
  });
  function getVisibleTrigger() {
    const customTriggers = document.querySelectorAll(
      '[data-element="conversion-banner-trigger"]'
    );
    for (const trigger of customTriggers) {
      const rect = trigger.getBoundingClientRect();
      if (rect.width > 0 && rect.height > 0) {
        return trigger;
      }
    }
    const headers = document.querySelectorAll('header');
    for (const header of headers) {
      const rect = header.getBoundingClientRect();
      if (rect.width > 0 && rect.height > 0) {
        return header;
      }
    }
    return null;
  }
  function handleViewportChange(event) {
    const matches =
      event instanceof MediaQueryList ? event.matches : event.matches;
    if (matches) {
      const visibleTrigger = getVisibleTrigger();
      if (visibleTrigger) {
        bannerObserver.observe(visibleTrigger);
      }
    } else {
      hideBanner();
      bannerObserver.disconnect();
    }
  }
  const mediaQuery = window.matchMedia('(max-width: 991px)');
  handleViewportChange(mediaQuery);
  mediaQuery.addEventListener('change', handleViewportChange);
});
</script>

<script>
"use strict";
document.addEventListener('DOMContentLoaded', () => {
    const conversionBannerButton = document.querySelector('[data-element="conversion-banner-button"]');
    if (!conversionBannerButton) {
        return;
    }
    const customUrl = conversionBannerButton.getAttribute('data-custom-url');
    if (customUrl && customUrl.trim() !== '') {
        const existingUrl = new URL(conversionBannerButton.href);
        const newUrl = new URL(customUrl);
        const existingParams = new URLSearchParams(existingUrl.search);
        existingParams.forEach((value, key) => {
            newUrl.searchParams.set(key, value);
        });
        const customUrlParams = new URLSearchParams(new URL(customUrl).search);
        customUrlParams.forEach((value, key) => {
            newUrl.searchParams.set(key, value);
        });
        conversionBannerButton.href = newUrl.toString();
    }
});
</script></div><div fs-cc="banner" class="a_cookie-banner"><div class="a_padding-global"><div class="a_cookie-banner_wrapper"><div class="a_cookies-text">We and our vendors use technology that collects or records personal information about your use of our site so we can improve and personalize our products and services, for analytics and marketing, and to fulfill your requests. We may also share this information with marketing vendors, social media companies, and analytics partners, which may be considered &quot;targeted advertising,&quot; &quot;selling,&quot; or &quot;sharing&quot; under some state laws. By using our website, you acknowledge and agree to our <a target="_blank" href="https://www.opus.pro/terms-of-service" class="white-link-white-underline white-underline"><span class="a_text-color-white white-link-white-underline">Terms of Use</span></a> and <a target="_blank" href="https://www.opus.pro/privacy-policy" class="white-link-white-underline white-underline"><span class="a_text-color-white white-link-white-underline">Privacy Policy</span></a>.</div><div class="a_cookie-banner_right-wrapper"><button fs-cc="close" aria-label="Hide cookie consent banner" class="a_cookie-banner_close"><img src="https://cdn.prod.website-files.com/6388604483b03a9ecb34d695/67d2ab5fdffcca62bee4eefe_xmark.svg" loading="lazy" alt="close icon" class="a_icon-1x1-xsmall"/></button></div></div></div></div></div></div><script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=6388604483b03a9ecb34d695" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/6388604483b03a9ecb34d695/js/opusclip-staging.schunk.36b8fb49256177c8.js" type="text/javascript" integrity="sha384-4abIlA5/v7XaW1HMXKBgnUuhnjBYJ/Z9C1OSg4OhmVw9O3QeHJ/qJqFBERCDPv7G" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/6388604483b03a9ecb34d695/js/opusclip-staging.schunk.6dab1630fcf68b2b.js" type="text/javascript" integrity="sha384-tTVNXyHNxoNAk0yiKhzZgG1Pgivyf/ulzLq/qWPM1onxIc5ki7DhFDdJEHRqqlr3" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/6388604483b03a9ecb34d695/js/opusclip-staging.38e26ae5.68900a8076a9f507.js" type="text/javascript" integrity="sha384-4u26/v7V6+7CfKdKS0a2N7tjW7dptG5jO4MbIxAn1+Djd3PeUvCn/fYNqJtq0h6i" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" type="text/javascript"></script><script async>
