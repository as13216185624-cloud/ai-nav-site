<script>
  // show conversion banner when the user scrolls past trigger on mobile
  const conversionBanner = document.querySelector(
    '[data-element="conversion-banner"]',
  )
  const conversionBannerTrigger = document.querySelector(
    '[data-element="conversion-banner-trigger"]',
  )
  let hideBannerTimeout
  function showConversionBanner() {
    if (!conversionBanner) return
    clearTimeout(hideBannerTimeout)
    conversionBanner.style.display = 'flex'
    conversionBanner.offsetHeight
    conversionBanner.style.opacity = '1'
  }
  function hideBanner() {
    if (!conversionBanner) return
    conversionBanner.style.opacity = '0'
    hideBannerTimeout = setTimeout(() => {
      conversionBanner.style.display = 'none'
    }, 300)
  }
  const conversionBannerObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        hideBanner()
      } else {
        showConversionBanner()
      }
    })
  })
  function handleViewportChange(event) {
    if (event.matches) {
      conversionBannerObserver.observe(conversionBannerTrigger)
    } else {
      hideBanner()
      conversionBannerObserver.unobserve(conversionBannerTrigger)
    }
  }
  const mediaQuery = window.matchMedia('(max-width: 991px)')
  handleViewportChange(mediaQuery)
  mediaQuery.addListener(handleViewportChange)
</script>

<!-- navbar banner -->
<!--
<script>
const navbarBannerCloseTrigger = document.querySelector('[data-element="navbar-banner-close-trigger"]');
const navbarBanner = document.querySelector('[data-element="navbar-banner"]');
const navbarBannerSpacer = document.querySelector('[data-element="navbar-banner-spacer"]');
window.addEventListener('load', () => {
    if (navbarBanner && navbarBannerSpacer) {
        const hideBanner = () => {
            navbarBanner.style.gridTemplateRows = '0fr';
            navbarBannerSpacer.style.gridTemplateRows = '0fr';
            setTimeout(() => {
                navbarBanner.style.display = 'none';
                navbarBannerSpacer.style.display = 'none';
            }, 200);
        };
        if (!getCookie('homepage-hide-navbar-banner')) {
            navbarBanner.style.display = 'grid';
            navbarBannerSpacer.style.display = 'grid';
            navbarBanner.style.gridTemplateRows = '0fr';
            navbarBannerSpacer.style.gridTemplateRows = '0fr';
            setTimeout(() => {
                navbarBanner.style.gridTemplateRows = '1fr';
                navbarBannerSpacer.style.gridTemplateRows = '1fr';
            });
        }
        navbarBannerCloseTrigger?.addEventListener('click', () => {
            setCookie('homepage-hide-navbar-banner', true, 180);
            hideBanner();
        });
    }
});
</script>
-->
</body></html>