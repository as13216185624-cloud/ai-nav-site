<script>
  const sources = document.getElementsByTagName('source')
  for (let source of sources) {
    const src = source.src
    if (src.endsWith('.webm')) {
      source.remove()
    }
  }
  window.Webflow ||= []
  window.Webflow.push(() => {
    // Prevent closing accordion on text link click inside answer
    const accordions = document.querySelectorAll('.a_nlp_faq_accordion')
    accordions.forEach((accordion) => {
