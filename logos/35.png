":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1813199806\u0026x-signature=kDkakD%2FTBYD%2FYbe0L%2FJCYoirrQE%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"一幅极致厚涂的插画特写，聚焦于一只橘猫的头部。画面以凌厉锋利的流线型笔触构建出强烈的动态与琉璃般的晶莹质感。猫咪拥有一张精致无瑕的面庞，双色异瞳（一只是琥珀黄，一则是翡翠绿）在垂眸间流泻出混合了张扬、冷酷、忧郁与高傲的复杂情绪。它一身蓬松的长毛被处理得极致细腻，凌乱而富有生命力的发束，一副银丝眼镜链随意垂落，与根根分明、锐利如刀的长睫毛相映成趣。整体色调为低饱和度，通过柔光与流体笔触的叠加，营造出一种既朦胧梦幻又充满锋利线条的视觉冲突，仿佛定格于现实与幻想的边界。","sample_steps":25,"seed":1693162274,"large_image_info":{"height":2560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7611726102318435634","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"极致厚涂插画特写，聚焦橘猫头部，凌厉流线型笔触构建动态，琉璃晶莹质感。猫咪面庞精致无瑕，双色异瞳（琥珀黄与翡翠绿）垂眸流露张扬、冷酷、忧郁、高傲复杂情绪。蓬松长毛细腻，凌乱发束富有生命力，银丝眼镜链随意垂落，与锐利长睫毛相映成趣。低饱和度色调，柔光与流体笔触叠加，营造朦胧梦幻与锋利线条的视觉冲突，现实与幻想边界氛围。","image_type":3},"statistic":{"usage_num":14,"favorite_num":247,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7611726102318435634","effect_id":"7611726102318435634","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/89080b6f4397416f86709f9da315bf04~tplv-tb4s082cfz-aigc_resize:640:640.png?lk3s=4fa96020\u0026x-expires=1813199808\u0026x-signature=bZztcb3h%2BKZ3lJx%2FnwBdpjGpHhE%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":"猫猫"},"author":{"name":"曾建国","avatar_url":"https://p9-passport.byteacctimg.com/img/user-avatar/9eaef939b4e03602a178bf9b60defb48~300x300.image","uid":"1922399233381662","sec_