tio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1813199806\u0026x-signature=kDkakD%2FTBYD%2FYbe0L%2FJCYoirrQE%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"插画，未来主义，光效应艺术风格，深邃蓝色背景，幻觉+重复+致幻，动态角度+大张力角度，视觉错觉，艺术感加强，超现实主义，氛围感加强，反光+珠光，超清晰，高级的氛围感 意识流，宇宙星空，浪漫灯塔，背景是一大片星空，星星颜色的鱼在天空中游动形成巨大的漩涡，幻想风格，充满了幻想和魔幻的元素，空中的巨型鲸鱼和星光，深蓝色的夜空，点缀闪烁的星星，宁静而神秘的氛围，浪漫而神秘，精细的描绘，梦幻，绚丽，仰视视角，氛围感，手绘风格，深蓝色调，风格定位：融合现代潮流元素与搞怪风格，形象整体看起来时尚、有趣且充满活力，适合年轻人的审美。细节细腻，风格清新。画面清晰。画面下方：主题用流动的毛笔手绘字体：“Don’t wait for inspiration”（纤细的笔画，笔画拉丝，灵动的曲线，有质感），极小的装饰性小字，极细无衬线小字体“2026”，白色极细无衬线字体水印\" LUOBOS \"+“ INSPIRATION ”+\" AIGC \"+\"Every great idea begins with a spark\"，质感，肌理感，梦幻的，耀变，反射，艺术抽象，诗意的，高级，杰作，极具视觉冲击力，获奖作品，大师级配色，大师级排版，高细节，高级感，超高清，布局协调。","sample_steps":16,"large_image_info":{"height":2496,"width":1664,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7636424031985601843","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"未来主义光效应艺术风格插画，融合现代潮流与搞怪风格，时尚有趣充满活力。深邃蓝色夜空背景，点缀闪烁星星，星星颜色的鱼在天空中游动形成巨大漩涡，空中有巨型鲸鱼和星光，浪漫灯塔矗立其中。动态大张力角度，仰视视角，视觉错觉，超现实主义意识流，反光珠光质感，精细描绘，梦幻绚丽，宁静神秘浪漫氛围。画面下方流动毛笔手绘字体\"Don’t wait for inspiration\"（纤细笔画、拉丝、灵动曲线、质感），极小极细无衬线装饰性小字\"2026\"，白色极细无衬线字体水印\"LUOBOS\"+\"INSPIRATION\"+\"AIGC\"+\"Every great idea begins with a spark\"，艺术抽象，诗意高级，大师级配色排版，高细节超高清，布局协调，极具视觉冲击力。","image_type":3},"statistic":{"usage_num":33,"favorite_num":431,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7636424031985601843","effect_id":"7636424031985601843","effect_type":9,"description":"#即梦AI创作者成长计划#即梦AI新视觉","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-