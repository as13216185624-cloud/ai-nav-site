o_type":1,"width":2048,"height":2048},{"ratio_type":2,"width":1728,"height":2304},{"ratio_type":3,"width":2560,"height":1440},{"ratio_type":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1813199806\u0026x-signature=kDkakD%2FTBYD%2FYbe0L%2FJCYoirrQE%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"伯莱塔92手枪的概念分解蓝图草图，在纯白色卡片背景上放置了一个超详细的3D渲染伯莱塔92手枪组件作为中心主题，以极广角，低视角的视角呈现，以产生强大的深度，戏剧性的规模压缩和视觉上令人惊叹的结构张力。主要结构元件包括枪管接收器、枪栓连动座、撞针、扳机组、弹匣盒、从动弹簧、黑色工程塑料枪托，所有这些都悬挂在精确对齐的轴向爆炸布局中，沿着主透视轴漂浮在空间中。主要渲染周围是密集的技术注释层：内部机械剖面图、螺栓循环轨迹图、后坐力方向箭头、装配序列流程图和材料标注。每个零件都标有毫米刻度的测量线，编号标签。","sample_steps":16,"seed":780460651,"large_image_info":{"height":2304,"width":1728,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7595963803209190665","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"概念分解蓝图草图，超详细3D渲染，纯白色卡片背景，极广角低视角，强大深度，戏剧性规模压缩，视觉结构张力。中心主题为伯莱塔92手枪组件，包括枪管接收器、枪栓连动座、撞针、扳机组、弹匣盒、从动弹簧、黑色工程塑料枪托，悬挂于精确对齐的轴向爆炸布局，沿主透视轴漂浮空间。周围密集技术注释层：内部机械剖面图、螺栓循环轨迹图、后坐力方向箭头、装配序列流程图、材料标注。每个零件带毫米刻度测量线与编号标签。","image_type":3},"statistic":{"usage_num":14,"favorite_num":183,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7595963803209190665","effect_id":"7595963803209190665","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/47732234b08e4f908bb375f794bc6063~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1813199808\u0026x-signature=oGii%2FRF3xSqEoVx0O%2BVbANw0NkU%3D","cover_url_map":null,"smart_crop_loc":null,